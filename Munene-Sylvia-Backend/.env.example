# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_ENGINE=django.db.backends.sqlite3
# For PostgreSQL (production):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=pennyprof
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# M-Pesa Daraja API (Sandbox Configuration)
# Get these from: https://developer.safaricom.co.ke
# 1. Go to Dashboard > My Apps
# 2. Create app, select API Lipa Na M-Pesa Online Checkout
# 3. Copy keys and generate credentials
MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
MPESA_BUSINESS_SHORTCODE=600371
MPESA_PASSKEY=your-daraja-passkey

# B2C Initiator Credentials
# Get from: https://developer.safaricom.co.ke > Sandbox > B2C Payments
MPESA_INITIATOR_NAME=testapi
MPESA_INITIATOR_PASSWORD=your-b2c-initiator-password

# M-Pesa Callback URL (for webhooks)
# Local development: http://localhost:8000/api/finance
# With ngrok tunnel: https://your-ngrok-url.ngrok-free.dev/api/v1/finance
MPESA_CALLBACK_URL=http://localhost:8000/api/finance

# Environment: sandbox or production
MPESA_ENVIRONMENT=sandbox

# Firebase (TODO: Configure)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# Celery (Optional - for background tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS (Frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Email (Optional - for notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=noreply@pennyprof.com
